<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>Upcoming Service Projects</h2>

        <% if (projects && projects.length> 0) { %>
            <ul class="text-left">
                <% projects.forEach(project=> { %>
                    <li>
                        <!-- 1. Fecha formateada -->
                        <%= new Date(project.date).toLocaleDateString('en-US', { weekday: 'long' , year: 'numeric' ,
                            month: 'long' , day: 'numeric' }) %>:

                            <!-- 2. Enlace a los detalles del proyecto usando su ID -->
                            <a href="/project/<%= project.project_id %>">
                                <%= project.title %>
                            </a>

                            <!-- 3. Enlace a los detalles de la organización usando su ID -->
                            (<a href="/organization/<%= project.organization_id %>">
                                <%= project.name %>
                            </a>)
                    </li>
                    <% }); %>
            </ul>

            <% } else { %>
                <ul class="text-left">
                    <li>Park Cleanup - Join us to clean up local parks and make them beautiful!</li>
                    <li>Food Drive - Help collect and distribute food to those in need.</li>
                    <li>Community Tutoring - Volunteer to tutor students in various subjects.</li>
                </ul>
                <p><em>More projects coming soon!</em></p>
                <% } %>

                    <% if (user && user.role_name==='admin' ) { %>
                        <a href="/new-project">Add a New Service Project</a>
                        <% } %>

    </main>
    <%- include('partials/footer') %>