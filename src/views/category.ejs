<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= categoryDetails.name %>
        </h2>

        <strong>Service Projects:</strong>
        <ul>
            <% projectByCategory.forEach(project=> { %>
                <li>
                    <a href="/project/<%=project.project_id%>">
                        <%= project.title %>
                    </a>
                </li>

                <% }); %>

        </ul>

    </main>

    <%- include('partials/footer') %>