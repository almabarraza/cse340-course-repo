<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <ul class="text-left">
            <% categories.forEach(category=> { %>
                <li>
                    <a href="/category/<%= category.category_id%>">
                        <%= category.name %>
                    </a>

                </li>

                <% }) %>

        </ul>

        <% if (user && user.role_name==='admin' ) { %>
            <a href="/new-category">Add a new Category</a>
            <% } %>


    </main>

    <%- include('partials/footer') %>